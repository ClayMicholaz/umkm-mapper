{
  "version": 2,
  "functions": {
    "api/[...all].js": {
      "runtime": "nodejs20.x"
    }
  },
  "buildCommand": "cd frontend && NPM_CONFIG_PRODUCTION=false npm install --legacy-peer-deps && npm run build",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/[...all].js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
